{
  "extends": "./tsconfig.app.json",
  "compilerOptions": {
    "declaration": true,
    "emitDeclarationOnly": true,
    "declarationDir": "dist",
    "outDir": "dist",
    "rootDir": "src",
    "noEmit": false,
    "skipLibCheck": true,
    "allowJs": false,
    "checkJs": false
  },
  "include": [
    "src/**/*"
  ]
}
